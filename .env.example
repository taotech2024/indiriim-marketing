# =============================================================================
# Marketing Frontend – Ortam değişkenleri
# Backend: indiriim-be-marketing (Kotlin/Spring Boot, varsayılan port 8092)
# =============================================================================
# Kopyala: cp .env.example .env
# Geliştirme: .env veya .env.development kullanılır (npm run dev)
# Production: .env.production kullanılır (npm run build); deploy öncesi API URL'i güncelleyin.
# =============================================================================

# --- Development (local) ---
# Backend bu makinede çalışıyorsa: http://localhost:8092
REACT_APP_API_URL=http://localhost:8092

# --- Production ---
# Build/deploy sırasında gerçek API adresi ile değiştirin (örn. https://api.indiriim.com)
# REACT_APP_API_URL=https://api.example.com

# --- Opsiyonel: Deploy subpath ---
# GitHub Pages veya subpath kullanıyorsanız (örn. /indiriim-marketing/)
# PUBLIC_PATH=/
